ENVIRONMENT=development
PULSE_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pulse
DATABASE_SSL=auto

# Use a unique 32+ character secret in production.
JWT_SECRET=change-this-to-a-long-random-production-secret
JWT_EXPIRES_MINUTES=10080

# Comma-separated list. Leave empty to use the built-in local + production origins.
CORS_ORIGINS=

# AI blocks read OPENAI_API_KEY first, then CHATGPT_API_KEY, then legacy TOCKEN_CHATGPT_API.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true
